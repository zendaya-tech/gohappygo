# Stripe Configuration
# Remplace par ta clé publique Stripe (commence par pk_test_ ou pk_live_)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# API
VITE_API_URL=https://api.gohappygo.fr/api

# Firebase Web App
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.europe-west1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
